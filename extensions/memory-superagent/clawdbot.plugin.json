{
  "id": "memory-superagent",
  "kind": "memory",
  "uiHints": {
    "server.baseUrl": {
      "label": "Server URL",
      "placeholder": "http://localhost:8080",
      "help": "SuperAgentMemory API server URL"
    },
    "server.apiKey": {
      "label": "API Key",
      "sensitive": true,
      "placeholder": "your-api-key (or use ${SUPERAGENT_MEMORY_API_KEY})",
      "help": "API key for SuperAgentMemory authentication"
    },
    "autoRecall": {
      "label": "Auto-Recall",
      "help": "Automatically inject relevant memories before agent starts"
    },
    "autoCapture": {
      "label": "Auto-Capture",
      "help": "Automatically capture important information after agent ends"
    },
    "activeRecall.enableQueryExpansion": {
      "label": "Enable Query Expansion",
      "advanced": true,
      "help": "Use intelligent query expansion for better recall accuracy"
    },
    "activeRecall.maxParallelQueries": {
      "label": "Max Parallel Queries",
      "advanced": true,
      "help": "Maximum number of expanded queries to execute in parallel"
    },
    "activeRecall.maxExpansions": {
      "label": "Max Expansions",
      "advanced": true,
      "help": "Maximum number of query expansions to generate"
    },
    "activeRecall.minQueryLength": {
      "label": "Min Query Length",
      "advanced": true,
      "help": "Minimum query length to trigger active recall"
    },
    "activeRecall.maxContextMemories": {
      "label": "Max Context Memories",
      "advanced": true,
      "help": "Maximum memories to inject into context"
    },
    "activeRecall.debugStrategy": {
      "label": "Debug Strategy",
      "advanced": true,
      "help": "Show search strategy in logs for debugging"
    },
    "defaults.maxResults": {
      "label": "Max Results",
      "advanced": true,
      "help": "Default max results for recall (default: 10)"
    },
    "defaults.maxDepth": {
      "label": "Ripple Depth",
      "advanced": true,
      "help": "Default ripple retrieval depth 1-5 (default: 3)"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "server": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "baseUrl": {
            "type": "string"
          },
          "apiKey": {
            "type": "string"
          }
        },
        "required": []
      },
      "autoCapture": {
        "type": "boolean"
      },
      "autoRecall": {
        "type": "boolean"
      },
      "activeRecall": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enableQueryExpansion": {
            "type": "boolean",
            "default": true
          },
          "maxParallelQueries": {
            "type": "number",
            "minimum": 1,
            "maximum": 10,
            "default": 3
          },
          "maxExpansions": {
            "type": "number",
            "minimum": 1,
            "maximum": 10,
            "default": 5
          },
          "minQueryLength": {
            "type": "number",
            "minimum": 1,
            "maximum": 50,
            "default": 5
          },
          "injectContext": {
            "type": "boolean",
            "default": true
          },
          "maxContextMemories": {
            "type": "number",
            "minimum": 1,
            "maximum": 20,
            "default": 5
          },
          "debugStrategy": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "defaults": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "maxResults": {
            "type": "number",
            "minimum": 1,
            "maximum": 50
          },
          "maxDepth": {
            "type": "number",
            "minimum": 1,
            "maximum": 5
          },
          "importance": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "decayFactor": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "minStrength": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "required": [
      "server"
    ]
  }
}
